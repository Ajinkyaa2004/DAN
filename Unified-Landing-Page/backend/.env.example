# Unified Landing Page Backend - Environment Variables

# Port (Vercel handles this automatically in production)
PORT=8080

# CORS Origins (comma-separated)
# Local: http://localhost:3003
# Production: https://your-unified-frontend.vercel.app,https://your-business-compass.vercel.app
CORS_ORIGINS=http://localhost:3003,http://localhost:3000

# Node Environment
NODE_ENV=development
