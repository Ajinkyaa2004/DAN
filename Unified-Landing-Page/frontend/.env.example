# Unified Landing Page Frontend - Environment Variables

# Backend API URL
# Local: http://localhost:8080
# Production: https://your-unified-backend.vercel.app
REACT_APP_API_URL=http://localhost:8080

# Business Compass URL (for redirect after upload)
# Local: http://localhost:3000
# Production: https://your-business-compass.vercel.app
REACT_APP_BUSINESS_COMPASS_URL=http://localhost:3000
